{
  "plugin": "debug-pvc",
  "version": "v0.1.0",
  "homepage": "https://github.com/zwindler/kubectl-debug-pvc",
  "description": "Creates an ephemeral debug container in a running pod and mounts one or\nmore PersistentVolumeClaim-backed volumes into it. Unlike kubectl debug,\nthis plugin supports volumeMounts on ephemeral containers by patching the\npod's ephemeralcontainers subresource directly via the Kubernetes API.\n\nBoth an interactive Bubble Tea TUI and a non-interactive CLI flag mode\nare provided.\n",
